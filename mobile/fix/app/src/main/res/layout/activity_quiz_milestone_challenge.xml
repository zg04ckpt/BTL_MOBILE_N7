<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_event"
    tools:context=".events.activities.QuizMilestoneChallengeActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/quiz_milestone_challenge"
        app:layout_constraintTop_toTopOf="parent"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:background="@color/color9"
            android:layout_margin="20dp"
            android:textColor="@color/color2"
            android:text="Vượt ải trắc nghiệm"/>

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color2"
            android:background="@color/color11"
            android:layout_marginHorizontal="20dp"
            android:text="Tiến độ 1/4"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:layout_height="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:elevation="4dp"
                android:background="@drawable/bg_card">

                <View
                    android:id="@+id/vProgressBarBg"
                    android:layout_width="20dp"
                    android:layout_height="100dp"
                    android:layout_gravity="start"
                    android:layout_marginStart="20dp"
                    android:background="@drawable/bg_quizmilestone_progress"/>

                <View
                    android:id="@+id/vProgressBar"
                    android:layout_width="20dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_quizmilestone_progress_completed"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvThresholds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_quizmilestone_progress"
                    tools:itemCount="1"/>

            </FrameLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="0dp"
            android:text="Quay lại"
            android:textColor="@color/color2"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/color9"
            app:cornerRadius="6dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>