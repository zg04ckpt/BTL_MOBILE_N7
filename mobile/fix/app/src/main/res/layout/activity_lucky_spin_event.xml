<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/background_event"
    tools:context=".events.activities.LuckySpinEventActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:textSize="30sp"
        android:textStyle="bold|italic"
        android:textColor="@color/color11"
        android:text="Vòng quay may mắn"/>

    <TextView
        android:id="@+id/tvRemainingSpinTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/color9"
        android:text="Số lượt quay còn lại: 0"/>

    <FrameLayout
        android:layout_marginTop="30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

<!--        <ImageView-->
<!--            android:id="@+id/wheel_body"-->
<!--            android:layout_width="260dp"-->
<!--            android:layout_height="260dp"-->
<!--            android:layout_gravity="center"-->
<!--            android:src="@drawable/vongquay" />-->

        <com.hoangcn.quizbattle.events.views.LuckyWheelView
            android:id="@+id/wheel_body"
            android:layout_width="260dp"
            android:layout_gravity="center"
            android:layout_height="260dp" />

        <ImageView
            android:id="@+id/wheel_arround"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:paddingBottom="16dp"
            android:layout_gravity="center"
            android:src="@drawable/khungvongquay" />

    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartSpin"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="12dp"
        android:text="Bắt đầu quay"
        android:textColor="@color/white"
        android:backgroundTint="@color/color1"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textAllCaps="false"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="12dp"
        android:text="Quay lại"
        android:textColor="@color/white"
        android:backgroundTint="@color/color9"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textAllCaps="false"/>

</LinearLayout>