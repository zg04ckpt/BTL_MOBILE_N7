<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".events.activities.LuckySpinEventActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/lucky_spin"
        app:layout_constraintTop_toTopOf="parent"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:background="@color/color1"
            android:textColor="@color/color2"
            android:text="Vòng quay may mắn"/>

        <TextView
            android:id="@+id/tvRemainingSpinTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color2"
            android:background="@color/color11"
            android:layout_marginTop="10dp"
            android:text="Số lượt quay còn lại: 0"/>

        <FrameLayout
            android:layout_marginTop="30dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!--        <ImageView-->
            <!--            android:id="@+id/wheel_body"-->
            <!--            android:layout_width="260dp"-->
            <!--            android:layout_height="260dp"-->
            <!--            android:layout_gravity="center"-->
            <!--            android:src="@drawable/vongquay" />-->

            <com.hoangcn.quizbattle.events.views.LuckyWheelView
                android:id="@+id/wheel_body"
                android:layout_width="260dp"
                android:layout_gravity="center"
                android:layout_height="260dp" />

            <ImageView
                android:id="@+id/wheel_arround"
                android:layout_width="320dp"
                android:layout_height="320dp"
                android:paddingBottom="16dp"
                android:layout_gravity="center"
                android:src="@drawable/khungvongquay" />

        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartSpin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="Bắt đầu quay"
            android:textColor="@color/white"
            android:backgroundTint="@color/color1"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="Quay lại"
            android:textColor="@color/white"
            android:backgroundTint="@color/color9"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textAllCaps="false"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>