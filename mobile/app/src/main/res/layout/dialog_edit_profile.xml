<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="27dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="true">
    
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chỉnh sửa hồ sơ"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/color1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        
        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_circle_border"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_current_avatar"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginTop="20dp"
            android:padding="2dp"
            android:src="@drawable/home_page_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_dialog_title"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeWidth="5dp"
            app:strokeColor="@color/color1"/>
        
        <TextView
            android:id="@+id/tv_change_avatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Thay đổi"
            android:textColor="@color/color11"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_current_avatar"/>

        <TextView
            android:id="@+id/tv_label_display_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Tên hiển thị"
            android:textColor="@color/color11"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_change_avatar"/>
        
        <EditText
            android:id="@+id/et_display_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/color3"
            android:textSize="14sp"
            android:text="Kenvin123"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_et_outline"
            app:layout_constraintTop_toBottomOf="@id/tv_label_display_name"/>
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_changes"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            app:cornerRadius="6dp"
            android:text="Lưu thay đổi"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="@color/color1"
            app:layout_constraintTop_toBottomOf="@id/et_display_name"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>