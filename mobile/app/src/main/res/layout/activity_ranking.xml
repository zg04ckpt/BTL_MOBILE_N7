<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".home_rank.activities.RankingActivity">

    <!-- Full-screen background image stretched to fill -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/bg_ranking"
        android:scaleType="fitXY"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title RANKING -->
    <TextView
        android:id="@+id/tvRankingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RANKING"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/color5"
        android:fontFamily="sans-serif-condensed"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Tab Weekly / Monthly / Total -->
    <LinearLayout
        android:id="@+id/layoutTabTime"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_tab_container"
        android:padding="3dp"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvRankingTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tabWeekly"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Weekly"
            android:textColor="@color/color2"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/bg_tab_selected" />

        <TextView
            android:id="@+id/tabMonthly"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Monthly"
            android:textColor="@color/color11"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/tabTotal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Total"
            android:textColor="@color/color11"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <!-- Tab Friend / Global -->
    <LinearLayout
        android:id="@+id/layoutTabScope"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_tab_container"
        android:padding="3dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/tabFriend"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:text="Friend"
            android:textColor="@color/color2"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/bg_tab_selected" />

        <TextView
            android:id="@+id/tabGlobal"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:text="Global"
            android:textColor="@color/color11"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <!-- Top 3 Podium -->
    <RelativeLayout
        android:id="@+id/layoutTopThree"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabScope"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <!-- Rank 1 (Center - Gold) -->
        <LinearLayout
            android:id="@+id/layoutRank1"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true">

            <ImageView
                android:id="@+id/ivRank1Avatar"
                android:layout_width="100dp"
                android:layout_height="90dp"
                android:src="@drawable/avatar_rank1"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvRank1Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user A"
                android:textColor="@color/color2"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvRank1Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="700 point"
                android:textColor="@color/color10"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Rank 2 (Left - Silver) -->
        <LinearLayout
            android:id="@+id/layoutRank2"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_toLeftOf="@id/layoutRank1"
            android:layout_marginTop="20dp">

            <ImageView
                android:id="@+id/ivRank2Avatar"
                android:layout_width="100dp"
                android:layout_height="90dp"
                android:src="@drawable/avatar_rank2"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvRank2Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user A"
                android:textColor="@color/color2"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvRank2Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="650 point"
                android:textColor="@color/color10"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Rank 3 (Right - Bronze) -->
        <LinearLayout
            android:id="@+id/layoutRank3"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_toRightOf="@id/layoutRank1"
            android:layout_marginTop="20dp">

            <ImageView
                android:id="@+id/ivRank3Avatar"
                android:layout_width="100dp"
                android:layout_height="90dp"
                android:src="@drawable/avatar_rank3"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvRank3Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user A"
                android:textColor="@color/color2"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvRank3Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="600 point"
                android:textColor="@color/color10"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout></RelativeLayout>

    <!-- Ranking List -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRankingList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/color2"
        app:layout_constraintTop_toBottomOf="@id/layoutTopThree"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutCurrentUser"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRankingList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            tools:listitem="@layout/item_ranking" />

    </androidx.cardview.widget.CardView>

    <!-- Current User Bar -->
    <LinearLayout
        android:id="@+id/layoutCurrentUser"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color11"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnBackToGame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCurrentUserRank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="23"
            android:textColor="@color/color2"
            android:textSize="16sp"
            android:textStyle="bold"
            android:minWidth="30dp"
            android:gravity="center" />

        <ImageView
            android:id="@+id/ivCurrentUserAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/avatar_current_user"
            android:scaleType="centerCrop"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_avatar_circle"
            android:padding="2dp" />

        <TextView
            android:id="@+id/tvCurrentUserName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="nguyễn văn A"
            android:textColor="@color/color2"
            android:textSize="14sp"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/tvCurrentUserScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="36 point"
            android:textColor="@color/color2"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Back to Game Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBackToGame"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Back to game"
        android:textColor="@color/color2"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_red"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
