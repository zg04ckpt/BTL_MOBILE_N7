<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_result"
    tools:context=".activities.MatchConfigActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/color1"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lựa chọn nội dung thi đấu"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/color1"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Kiểu thi đấu section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kiểu thi đấu"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/color1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <!-- Đấu đơn vượt ải -->
            <LinearLayout
                android:id="@+id/cardDauDon"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginEnd="15dp"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:orientation="vertical"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đấu đơn\nvượt ải"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/color1"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Đấu đội (selected) -->
            <LinearLayout
                android:id="@+id/cardDauDoi"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card_selected"
                android:gravity="center"
                android:orientation="vertical"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đấu đội"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Thi đấu với người chơi khác với thời gian cố định"
            android:textSize="12sp"
            android:textColor="@color/color11"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Số lượng người chơi section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số lượng người chơi"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/color1"
            android:layout_marginBottom="10dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingEnd="4dp">

                <LinearLayout
                    android:id="@+id/card1Nguoi"
                    android:layout_width="90dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_option_card"
                    android:gravity="center"
                    android:elevation="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Người"
                        android:textSize="14sp"
                        android:textColor="@color/color11" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card2Nguoi"
                    android:layout_width="90dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_option_card_selected"
                    android:gravity="center"
                    android:elevation="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 Người"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/color2" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card5Nguoi"
                    android:layout_width="90dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_option_card"
                    android:gravity="center"
                    android:elevation="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Người"
                        android:textSize="14sp"
                        android:textColor="@color/color11" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card10Nguoi"
                    android:layout_width="90dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_option_card"
                    android:gravity="center"
                    android:elevation="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 Người"
                        android:textSize="14sp"
                        android:textColor="@color/color11" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Chủ đề thi đấu section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chủ đề thi đấu"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/color1"
            android:layout_marginBottom="10dp" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:id="@+id/cardHonHop"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:elevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hỗn hợp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/color1"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardNgauNhien"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:elevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngẫu nhiên"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/color1"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardToanLop1"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card_selected"
                android:gravity="center"
                android:elevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toán lớp 1"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/color2"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Toán lớp 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/cardToanLop2"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:elevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toán lớp 2"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/color1"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Empty placeholders to keep grid alignment -->
            <View
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Confirm button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_marginTop="100dp"
            android:layout_height="56dp"
            android:text="Xác nhận"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/color2"
            app:backgroundTint="@color/color1"
            app:cornerRadius="8dp"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
