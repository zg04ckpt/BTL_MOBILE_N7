<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".events.activities.QuizMilestoneChallengeActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/quiz_milestone_challenge"
        app:layout_constraintTop_toTopOf="parent"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Overlay tối để làm nổi bật nội dung -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:textSize="26sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_home"
            app:backgroundTint="@color/color9"
            android:layout_margin="20dp"
            android:textColor="@color/color2"
            android:text="Vượt ải trắc nghiệm"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2"/>

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/color2"
            android:background="#CC000000"
            android:layout_marginHorizontal="20dp"
            android:text="Tiến độ 0/0"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:layout_height="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:elevation="4dp"
                android:background="@drawable/bg_card_white">

                <View
                    android:id="@+id/vProgressBarBg"
                    android:layout_width="16dp"
                    android:layout_height="100dp"
                    android:layout_gravity="start"
                    android:layout_marginStart="24dp"
                    android:background="@drawable/bg_quizmilestone_progress"/>

                <View
                    android:id="@+id/vProgressBar"
                    android:layout_width="16dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="24dp"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_quizmilestone_progress_completed"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvThresholds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_quizmilestone_progress"
                    tools:itemCount="3"/>

            </FrameLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="20dp"
            android:text="QUAY LẠI"
            android:textColor="@color/color2"
            android:textStyle="bold"
            android:textSize="18sp"
            android:background="@drawable/bg_button_home"
            app:backgroundTint="@color/color9"
            app:cornerRadius="28dp"
            app:elevation="4dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>