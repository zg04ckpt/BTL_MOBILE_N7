<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".events.activities.LuckySpinEventActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/lucky_spin" />

    <!-- Overlay tối hơn một chút để nổi bật vòng quay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_home"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:text="Vòng quay may mắn"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:backgroundTint="@color/color1"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2"/>

        <TextView
            android:id="@+id/tvRemainingSpinTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_tag_event_time_type"
            android:backgroundTint="#CC000000"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:text="Số lượt quay còn lại: 0"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginTop="20dp">

            <com.hoangcn.quizbattle.events.views.LuckyWheelView
                android:id="@+id/wheel_body"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_gravity="center" />

            <ImageView
                android:id="@+id/wheel_arround"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:paddingBottom="16dp"
                android:src="@drawable/khungvongquay" />

        </FrameLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartSpin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_join_event"
            android:text="BẮT ĐẦU QUAY"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="30dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_home"
            android:text="QUAY LẠI"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/color9"
            app:cornerRadius="28dp"
            app:elevation="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>