<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuizBattle">
        <activity
            android:name=".battles.activities.MatchActivity"
            android:exported="false" />
        <activity
            android:name=".battles.activities.BattleActivity"
            android:exported="false" />
        <activity
            android:name=".events.activities.TournamentRewardsEventActivity"
            android:exported="false" />
        <activity
            android:name=".events.activities.TournamentRewardsEvetnActivity"
            android:exported="false" />
        <activity
            android:name=".events.activities.QuizMilestoneChallengeActivity"
            android:exported="false" />
        <activity
            android:name=".events.activities.LuckySpinEventActivity"
            android:exported="false" />
        <activity
            android:name=".home_rank.activities.HomeActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.QuizBattle">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".users.activities.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".users.activities.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".users.activities.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".battles.activities.WaitResultActivity"
            android:exported="false" />
        <activity
            android:name=".battles.activities.MatchResultActivity"
            android:exported="false" />
        <activity
            android:name=".home_rank.activities.RankingActivity"
            android:exported="false" />
        <activity
            android:name=".lobby.activities.MatchConfigActivity"
            android:exported="false" />
        <activity
            android:name=".lobby.activities.MatchMakingActivity"
            android:exported="false" />
        <activity
            android:name=".events.activities.EventActivity"
            android:exported="false" />
    </application>

</manifest>